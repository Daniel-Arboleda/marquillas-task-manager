@'
# Environment and secrets
.env
.env.*
!.env.example
frontend/.env
frontend/.env.*
!frontend/.env.example
backend/.env
backend/.env.*
!backend/.env.example

# Python
__pycache__/
*.py[cod]
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.venv/
venv/

# Node and Vite
frontend/node_modules/
frontend/dist/
frontend/.vite/

# IDE
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/

# Operating system
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Database and local volumes
data/
sqlserver-data/

# Generated
*.egg-info/

# OpenAPI generated artifact
openapi.json

# Temporary architecture documentation
tmp/

'@ | Set-Content .gitignore